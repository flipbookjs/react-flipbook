{
  "name": "@flipbookjs/react-viewer",
  "version": "1.0.3",
  "description": "React PDF flipbook viewer with page curl effect",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./toolbar-parts": {
      "import": "./dist/toolbar-parts.js",
      "require": "./dist/toolbar-parts.cjs",
      "types": "./dist/toolbar-parts.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "MIGRATION.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "pdfjs-dist": "^5.6.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "pdfjs-dist": "^5.6.205"
  },
  "keywords": [
    "react",
    "pdf",
    "flipbook",
    "page-curl",
    "viewer",
    "pdfjs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flipbookjs/react-flipbook"
  },
  "dependencies": {}
}
